{
  "name": "react-native-usb-serialport-for-android",
  "version": "0.4.1",
  "description": "react-native-usb-serialport-for-android",
  "main": "dist/cjs/index.js",
  "types": "dist/esm/index.d.ts",
  "module": "dist/esm/index.js",
  "react-native": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "start": "react-native start",
    "typescript": "tsc --noEmit",
    "prepack": "bob build",
    "release": "release-it",
    "build:plugin": "tsc --build plugin",
    "clean:plugin": "expo-module clean plugin",
    "prepare": "npm run build",
    "prebuild": "npm run clean && npm run clean:plugin",
    "build:cjs": "tsc --module commonjs --outDir dist/cjs",
    "build:esm": "tsc --outDir dist/esm",
    "build": "npm run build:esm && npm run build:cjs",
    "clean": "expo-module clean",
    "test": "expo-module test",
    "prepublishOnly": "expo-module prepublishOnly"
  },
  "codegenConfig": {
    "name": "UsbSerialportForAndroid",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.bastengao.usbserialport"
    }
  },
  "keywords": [
    "react-native",
    "android",
    "usb",
    "serialport"
  ],
  "repository": "https://github.com/bastengao/react-native-usb-serialport-for-android",
  "author": "bastengao <bastengao@gmail.com> (https://github.com/bastengao)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bastengao/react-native-usb-serialport-for-android/issues"
  },
  "homepage": "https://github.com/bastengao/react-native-usb-serialport-for-android",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@evilmartians/lefthook": "^2.1.4",
    "@react-native-community/cli": "20.1.2",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "^0.84.1",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.0",
    "commitlint": "^20.5.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "expo-module-scripts": "^55.0.2",
    "jest": "^30.3.0",
    "prettier": "^3.6.2",
    "react": "19.2.4",
    "react-native": "0.81.1",
    "react-native-builder-bob": "^0.40.13",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "19.2.4",
    "react-native": "0.84.1"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native-community",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "packageManager": "yarn@4.9.4",
  "dependencies": {
    "expo": "^55.0.7",
    "package": "^1.0.1",
    "react": "19.2.0",
    "react-native": "0.83.2"
  }
}